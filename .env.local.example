# Copy to .env.local and fill in. NEVER commit .env.local.

# ---------- Copy generation ----------
# Anthropic — Claude Haiku 4.5 for headline generation (server-side only)
ANTHROPIC_API_KEY=sk-ant-...

# ---------- Teams escalation (pick ONE transport) ----------
# Priority order: MOCK > Graph > n8n

# Option A: Mock — logs payload to console, does not contact Teams
MOCK_TEAMS=1

# Option B: Microsoft Graph direct (preferred for production)
# Azure app registration with app permissions: Chat.Create + ChatMessage.Send
# (admin-consented). Client-credentials flow.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# Option C: n8n workflow (if Graph is not available)
# Separate workflow from windmar-home/teams-n8n-bridge (homie).
# Uses the same X-Auth-Token auth pattern as homie.
N8N_WEBHOOK_URL=
N8N_AUTH_TOKEN=

# ---------- Escalation recipients ----------
ESCALATION_DESIGNER_EMAIL=jaime.diaz@windmarhome.com
ESCALATION_OWNER_EMAIL=miguel@windmarhome.com

# ---------- Deploy (optional) ----------
VERCEL_TOKEN=
