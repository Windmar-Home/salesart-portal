# Copy to .env.local and fill in. NEVER commit .env.local.

# Anthropic — copy generation (server-side only)
ANTHROPIC_API_KEY=sk-ant-...

# Microsoft Graph — Teams escalation (client-credentials / app-only auth)
# Azure app needs: Chat.Create, ChatMessage.Send (application permissions, admin consented)
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# Recipients for escalation
ESCALATION_DESIGNER_EMAIL=jaime.diaz@windmarhome.com
ESCALATION_OWNER_EMAIL=miguel@windmarhome.com

# Set to "1" to skip real MS Graph calls and log to console instead
MOCK_TEAMS=0

# Vercel (only needed if deploying from CLI in this sandbox)
VERCEL_TOKEN=
