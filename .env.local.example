# Copy to .env.local and fill in. NEVER commit .env.local.

# Anthropic — copy generation (server-side only)
ANTHROPIC_API_KEY=sk-ant-...

# n8n webhook — Teams escalation
# URL: new workflow in same n8n as windmar-home/teams-n8n-bridge (homie)
#      path suggestion: /webhook/salesart-escalate
# Auth: same shared secret pattern as homie (X-Auth-Token header)
N8N_WEBHOOK_URL=
N8N_AUTH_TOKEN=

# Recipients for escalation
ESCALATION_DESIGNER_EMAIL=jaime.diaz@windmarhome.com
ESCALATION_OWNER_EMAIL=miguel@windmarhome.com

# Set to "1" to skip real n8n calls and log to console instead
MOCK_TEAMS=0

# Vercel (only needed if deploying from CLI in this sandbox)
VERCEL_TOKEN=
